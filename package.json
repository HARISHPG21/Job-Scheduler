{
  "name": "distributed-job-scheduler-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "worker",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently -n backend,worker,frontend -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:worker\" \"npm run dev:frontend\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
